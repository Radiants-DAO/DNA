{
  "$schema": "https://knip.dev/schema.json",
  "ignoreWorkspaces": [
    ".",
    "apps/*",
    "tools/*",
    "templates/*"
  ],
  "ignore": [
    ".component-contracts.example",
    "**/.DS_Store",
    "**/.next/**",
    "**/.turbo/**",
    "packages/radiants/generated/figma/**"
  ],
  "workspaces": {
    "packages/preview": {
      "ignoreFiles": [
        "src/generate-schemas.ts"
      ]
    },
    "packages/ctrl": {
      "entry": [
        "index.ts",
        "{controls,selectors,readouts,layout}/index.ts",
        "**/*.meta.ts"
      ],
      "ignoreFiles": [
        "**/*.meta.ts"
      ]
    },
    "packages/radiants": {
      "ignoreDependencies": [
        "@chenglou/pretext"
      ],
      "ignoreFiles": [
        "contract/system.ts",
        "eslint/lib/no-legacy-color-format.mjs",
        "patterns/pretext-hyphenation.ts",
        "patterns/pretext-justify.ts",
        "patterns/pretext-prepare.ts",
        "patterns/pretext-type-scale.ts",
        "scripts/generate-figma-contracts.ts",
        "scripts/generate-pixel-corners.mjs",
        "scripts/generate-typography-tokens.ts",
        "scripts/pixel-corners-lib.mjs",
        "scripts/pixel-corners.config.mjs"
      ]
    }
  }
}
