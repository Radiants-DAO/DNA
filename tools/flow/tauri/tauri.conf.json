{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RadFlow",
  "version": "0.1.0",
  "identifier": "com.radflow.app",
  "build": {
    "beforeDevCommand": "pnpm build:bridge && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:bridge && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "RadFlow",
        "width": 1440,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 700,
        "maximized": true,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/bridge/**/*"
    ]
  }
}
