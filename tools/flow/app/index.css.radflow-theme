@import "tailwindcss";
@import "../packages/theme-rad-os/index.css";

/* Frameless window styles - Tauri-specific overrides */
#root {
  height: 100%;
  overflow: hidden;
}

/* Data attribute for window drag region */
[data-tauri-drag-region] {
  -webkit-app-region: drag;
}

[data-tauri-drag-region] * {
  -webkit-app-region: no-drag;
}

/* Prevent text selection in UI chrome */
.select-none {
  -webkit-user-select: none;
  user-select: none;
}
