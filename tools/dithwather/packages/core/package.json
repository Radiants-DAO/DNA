{
  "name": "@rdna/dithwather-core",
  "version": "0.0.1",
  "description": "Pure JS dithering engine with classic algorithms",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rivermassey/dithwather.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/rivermassey/dithwather/tree/main/packages/core#readme",
  "bugs": "https://github.com/rivermassey/dithwather/issues",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "typegpu": "^0.4.0"
  },
  "devDependencies": {
    "@webgpu/types": "^0.1.54",
    "canvas": "^3.2.1",
    "jsdom": "^28.0.0",
    "tsup": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "dithering",
    "bayer",
    "floyd-steinberg",
    "retro",
    "pixel-art",
    "image-processing"
  ]
}
