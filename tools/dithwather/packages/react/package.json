{
  "name": "@rdna/dithwather-react",
  "version": "0.0.1",
  "description": "React components and hooks for dithering effects",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rivermassey/dithwather.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/rivermassey/dithwather/tree/main/packages/react#readme",
  "bugs": "https://github.com/rivermassey/dithwather/issues",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --external react --external react-dom --external @rdna/dithwather-core",
    "dev": "tsup src/index.ts --format esm --dts --watch --external react",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@rdna/dithwather-core": "workspace:^"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^28.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "react",
    "dithering",
    "bayer",
    "retro",
    "ui",
    "animation"
  ]
}
