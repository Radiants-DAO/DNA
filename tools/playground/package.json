{
  "name": "@rdna/playground",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3004",
    "registry:watch": "node scripts/watch-registry.mjs",
    "check:registry-freshness": "node scripts/check-registry-freshness.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "verify:iterations": "node scripts/verify-generated-variation.mjs",
    "registry:generate": "node --experimental-strip-types scripts/generate-registry.ts",
    "violations:generate": "node scripts/generate-violations-manifest.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@rdna/radiants": "workspace:*",
    "@xyflow/react": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "html-to-image": "^1.11.13",
    "next": "16.1.6",
    "react": "19.2.1",
    "react-dom": "19.2.1"
  },
  "dna": {
    "port": 3004,
    "theme": "@rdna/radiants",
    "previewRoute": "/playground"
  },
  "bin": {
    "rdna-playground": "./bin/rdna-playground.mjs"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "tailwindcss": "^4",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
