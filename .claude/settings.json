{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/playground-work-signal.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/playground-annotation-inject.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
