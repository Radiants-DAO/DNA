{
  "name": "Switch",
  "description": "Toggle switch component for on/off states with label support.",
  "props": {
    "checked": {
      "type": "boolean",
      "description": "Checked state (controlled)"
    },
    "onChange": {
      "type": "function",
      "description": "Change handler callback"
    },
    "size": {
      "type": "enum",
      "values": ["sm", "md", "lg"],
      "default": "md",
      "description": "Size preset"
    },
    "disabled": {
      "type": "boolean",
      "default": false,
      "description": "Disabled state"
    },
    "label": {
      "type": "string",
      "description": "Label text"
    },
    "labelPosition": {
      "type": "enum",
      "values": ["left", "right"],
      "default": "right",
      "description": "Label position relative to switch"
    }
  },
  "examples": [
    {
      "name": "Basic switch",
      "code": "<Switch checked={isOn} onChange={setIsOn} />"
    },
    {
      "name": "With label",
      "code": "<Switch checked={enabled} onChange={setEnabled} label=\"Enable notifications\" />"
    },
    {
      "name": "Label on left",
      "code": "<Switch checked={active} onChange={setActive} label=\"Active\" labelPosition=\"left\" />"
    },
    {
      "name": "Disabled",
      "code": "<Switch checked={false} onChange={() => {}} disabled label=\"Unavailable\" />"
    }
  ]
}
