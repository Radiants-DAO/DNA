{
  "component": "Input",
  "description": "Token bindings for Input component variants",
  "tokenBindings": {
    "base": {
      "font": "alfacad",
      "focusRing": "action-primary"
    },
    "default": {
      "background": "surface-primary",
      "text": "content-primary",
      "border": "edge-primary",
      "placeholder": "content-secondary"
    },
    "dark": {
      "background": "surface-secondary",
      "text": "content-inverted",
      "border": "edge-inverted",
      "placeholder": "content-secondary",
      "focusRing": "edge-inverted"
    },
    "error": {
      "border": "status-error",
      "focusRing": "status-error"
    }
  },
  "states": {
    "disabled": {
      "opacity": "50%",
      "cursor": "not-allowed"
    },
    "focus": {
      "ring": "2px",
      "ringColor": "action-primary"
    }
  }
}
