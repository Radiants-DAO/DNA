{
  "name": "@rdna/radiants",
  "version": "0.1.0",
  "description": "Radiants theme package for DNA - retro pixel aesthetic",
  "main": "./index.css",
  "exports": {
    ".": "./index.css",
    "./tokens": "./tokens.css",
    "./dark": "./dark.css",
    "./animations": "./animations.css",
    "./base": "./base.css",
    "./typography": "./typography.css",
    "./fonts": "./fonts.css",
    "./components/core": "./components/core/index.ts",
    "./icons": {
      "types": "./icons/index.ts",
      "import": "./icons/index.ts"
    },
    "./schemas": {
      "types": "./schemas/index.ts",
      "import": "./schemas/index.ts"
    },
    "./eslint": {
      "import": "./eslint/index.mjs"
    },
    "./registry": {
      "types": "./registry/index.ts",
      "import": "./registry/index.ts"
    },
    "./meta": {
      "types": "./meta/index.ts",
      "import": "./meta/index.ts"
    },
    "./patterns": {
      "types": "./patterns/index.ts",
      "import": "./patterns/index.ts"
    }
  },
  "files": [
    "*.css",
    "components/",
    "icons/",
    "schemas/",
    "fonts/Joystix.woff2",
    "fonts/PixelCode*.woff2",
    "assets/",
    "dna.config.json",
    "LICENSE",
    "README.md",
    "eslint/",
    "generated/",
    "contract/",
    "registry/",
    "patterns/",
    "meta/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Radiants-DAO/DNA.git",
    "directory": "packages/radiants"
  },
  "homepage": "https://github.com/Radiants-DAO/DNA/tree/master/packages/radiants",
  "bugs": {
    "url": "https://github.com/Radiants-DAO/DNA/issues"
  },
  "peerDependencies": {
    "next": "^14.0.0 || ^15.0.0 || ^16.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "keywords": [
    "dna",
    "theme",
    "design-system",
    "retro",
    "pixel",
    "tailwind",
    "react",
    "components"
  ],
  "license": "GPL-3.0",
  "scripts": {
    "generate:icons": "node scripts/generate-icons.mjs",
    "generate:schemas": "node --experimental-strip-types ../preview/src/generate-schemas.ts ./components/core ./meta/index.ts ./schemas/index.ts",
    "generate:pixel-corners": "node scripts/generate-pixel-corners.mjs",
    "test:components": "vitest run",
    "test:components:watch": "vitest"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "culori": "^4.0.2",
    "eslint": "^9",
    "jsdom": "^28.1.0",
    "next": "16.1.6",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@rdna/preview": "workspace:*",
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1"
  }
}
