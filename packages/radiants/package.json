{
  "name": "@rdna/radiants",
  "version": "0.1.7",
  "description": "Radiants theme package for DNA - retro pixel aesthetic",
  "publishConfig": {
    "access": "public"
  },
  "main": "./index.css",
  "exports": {
    ".": "./index.css",
    "./tokens": "./tokens.css",
    "./dark": "./dark.css",
    "./america": "./america.css",
    "./animations": "./animations.css",
    "./base": "./base.css",
    "./typography": "./typography.css",
    "./fonts": "./fonts.css",
    "./components/core": "./components/core/index.ts",
    "./icons": {
      "types": "./icons/index.ts",
      "import": "./icons/index.ts"
    },
    "./icons/runtime": {
      "types": "./icons/runtime.ts",
      "import": "./icons/runtime.ts"
    },
    "./schemas": {
      "types": "./schemas/index.ts",
      "import": "./schemas/index.ts"
    },
    "./eslint": {
      "import": "./eslint/index.mjs"
    },
    "./registry": {
      "types": "./registry/index.ts",
      "import": "./registry/index.ts"
    },
    "./meta": {
      "types": "./meta/index.ts",
      "import": "./meta/index.ts"
    },
    "./patterns": {
      "types": "./patterns/index.ts",
      "import": "./patterns/index.ts"
    },
    "./blocknote": {
      "types": "./generated/blocknote-blocks.tsx",
      "import": "./generated/blocknote-blocks.tsx"
    }
  },
  "files": [
    "*.css",
    "components/",
    "icons/",
    "schemas/",
    "fonts/",
    "assets/",
    "dna.config.json",
    "LICENSE",
    "README.md",
    "eslint/",
    "generated/",
    "contract/",
    "registry/",
    "patterns/",
    "meta/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Radiants-DAO/DNA.git",
    "directory": "packages/radiants"
  },
  "homepage": "https://github.com/Radiants-DAO/DNA/tree/master/packages/radiants",
  "bugs": {
    "url": "https://github.com/Radiants-DAO/DNA/issues"
  },
  "peerDependencies": {
    "@blocknote/core": "^0.47.0",
    "@blocknote/react": "^0.47.0",
    "next": "^14.0.0 || ^15.0.0 || ^16.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "@blocknote/core": {
      "optional": true
    },
    "@blocknote/react": {
      "optional": true
    }
  },
  "keywords": [
    "dna",
    "theme",
    "design-system",
    "retro",
    "pixel",
    "tailwind",
    "react",
    "components"
  ],
  "license": "GPL-3.0",
  "scripts": {
    "generate:icons": "node --experimental-strip-types scripts/generate-icons.ts",
    "generate:schemas": "node --experimental-strip-types ../preview/src/generate-schemas.ts ./components/core ./meta/index.ts ./schemas/index.ts",
    "generate:figma-contracts": "node --experimental-strip-types scripts/generate-figma-contracts.ts",
    "generate:pixel-corners": "node scripts/generate-pixel-corners.mjs",
    "generate:tokens": "node --experimental-strip-types scripts/generate-typography-tokens.ts",
    "generate:blocknote": "node --experimental-strip-types scripts/generate-blocknote-blocks.ts",
    "test": "vitest run",
    "test:ci": "vitest run",
    "test:components": "vitest run",
    "test:components:watch": "vitest"
  },
  "devDependencies": {
    "@blocknote/core": "^0.47.3",
    "@blocknote/react": "^0.47.3",
    "@rdna/preview": "workspace:*",
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "culori": "^4.0.2",
    "eslint": "^9",
    "jsdom": "^28.1.0",
    "next": "16.1.6",
    "svgo": "^4.0.1",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@chenglou/pretext": "^0.0.4",
    "class-variance-authority": "^0.7.1",
    "motion": "^12.38.0",
    "react-draggable": "^4.5.0"
  }
}
