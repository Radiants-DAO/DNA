{
  "$schema": "./ai-contract.schema.json",
  "contractVersion": "0.1.0",
  "system": {
    "name": "RDNA Radiants",
    "description": "Retro pixel-art design system with two-tier semantic tokens, headless Base UI primitives, and Tailwind v4 native theming.",
    "colorModes": [
      "light",
      "dark"
    ],
    "importBase": "@rdna/radiants/components/core"
  },
  "rules": [
    {
      "id": "use-semantic-tokens",
      "severity": "error",
      "summary": "Always use semantic token classes, never hardcoded colors.",
      "do": "className=\"bg-page text-main border-line\"",
      "dont": "className=\"bg-[#FEF8E2] text-[#0F0E0C]\""
    },
    {
      "id": "use-rdna-components",
      "severity": "warn",
      "summary": "Use RDNA components instead of raw HTML elements when a replacement exists.",
      "do": "<Button>Submit</Button>",
      "dont": "<button>Submit</button>"
    },
    {
      "id": "pixel-corner-no-border",
      "severity": "error",
      "summary": "Never set border-color or overflow-hidden on pixel-cornered elements. The ::after pseudo-element handles visible borders."
    },
    {
      "id": "pixel-corner-no-shadow",
      "severity": "error",
      "summary": "Use pixel-shadow-* instead of shadow-* on pixel-cornered elements. Box-shadow gets clipped by clip-path."
    },
    {
      "id": "motion-constraints",
      "severity": "warn",
      "summary": "Use RDNA motion tokens. Max duration 300ms. Only ease-out easing."
    },
    {
      "id": "no-removed-aliases",
      "severity": "error",
      "summary": "These CSS custom properties have been removed and must not be used.",
      "bannedTokens": [
        "--color-black",
        "--color-white",
        "--color-green",
        "--color-success-green",
        "--glow-green"
      ]
    }
  ],
  "tokens": {
    "colors": {
      "description": "Two-tier system. Tier 1 (brand) = raw palette. Tier 2 (semantic) = purpose-based, flips in dark mode. Always use Tier 2.",
      "semantic": {
        "backgrounds": [
          {
            "suffix": "page",
            "use": "page"
          },
          {
            "suffix": "card",
            "use": "card"
          },
          {
            "suffix": "tinted",
            "use": "tinted"
          },
          {
            "suffix": "inv",
            "use": "inv"
          },
          {
            "suffix": "depth",
            "use": "depth"
          },
          {
            "suffix": "hover",
            "use": "hover"
          },
          {
            "suffix": "active",
            "use": "active"
          },
          {
            "suffix": "surface-primary",
            "use": "surface-primary"
          },
          {
            "suffix": "surface-secondary",
            "use": "surface-secondary"
          },
          {
            "suffix": "surface-elevated",
            "use": "surface-elevated"
          }
        ],
        "text": [
          {
            "suffix": "main",
            "use": "main"
          },
          {
            "suffix": "sub",
            "use": "sub"
          },
          {
            "suffix": "mute",
            "use": "mute"
          },
          {
            "suffix": "flip",
            "use": "flip"
          },
          {
            "suffix": "head",
            "use": "head"
          },
          {
            "suffix": "link",
            "use": "link"
          },
          {
            "suffix": "content-primary",
            "use": "content-primary"
          },
          {
            "suffix": "content-heading",
            "use": "content-heading"
          },
          {
            "suffix": "content-secondary",
            "use": "content-secondary"
          },
          {
            "suffix": "content-inverted",
            "use": "content-inverted"
          },
          {
            "suffix": "content-muted",
            "use": "content-muted"
          },
          {
            "suffix": "content-link",
            "use": "content-link"
          }
        ],
        "borders": [
          {
            "suffix": "line",
            "use": "line"
          },
          {
            "suffix": "rule",
            "use": "rule"
          },
          {
            "suffix": "line-hover",
            "use": "line-hover"
          },
          {
            "suffix": "focus",
            "use": "focus"
          },
          {
            "suffix": "edge-primary",
            "use": "edge-primary"
          },
          {
            "suffix": "edge-muted",
            "use": "edge-muted"
          },
          {
            "suffix": "edge-hover",
            "use": "edge-hover"
          },
          {
            "suffix": "edge-focus",
            "use": "edge-focus"
          }
        ],
        "accents": [
          {
            "suffix": "accent",
            "use": "accent"
          },
          {
            "suffix": "accent-inv",
            "use": "accent-inv"
          },
          {
            "suffix": "accent-soft",
            "use": "accent-soft"
          },
          {
            "suffix": "danger",
            "use": "danger"
          },
          {
            "suffix": "action-primary",
            "use": "action-primary"
          },
          {
            "suffix": "action-secondary",
            "use": "action-secondary"
          },
          {
            "suffix": "action-accent",
            "use": "action-accent"
          },
          {
            "suffix": "action-destructive",
            "use": "action-destructive"
          }
        ],
        "status": [
          {
            "suffix": "success",
            "use": "success"
          },
          {
            "suffix": "warning",
            "use": "warning"
          },
          {
            "suffix": "status-success",
            "use": "status-success"
          },
          {
            "suffix": "status-warning",
            "use": "status-warning"
          },
          {
            "suffix": "status-error",
            "use": "status-error"
          },
          {
            "suffix": "status-info",
            "use": "status-info"
          }
        ],
        "other": [
          {
            "suffix": "window-chrome-from",
            "use": "window-chrome-from"
          },
          {
            "suffix": "window-chrome-to",
            "use": "window-chrome-to"
          }
        ]
      },
      "brand": [
        {
          "name": "cream",
          "hex": "#fef8e2"
        },
        {
          "name": "ink",
          "hex": "#0f0e0c"
        },
        {
          "name": "pure-black",
          "hex": "#000000"
        },
        {
          "name": "sun-yellow",
          "hex": "#fce184"
        },
        {
          "name": "sky-blue",
          "hex": "#95bad2"
        },
        {
          "name": "sunset-fuzz",
          "hex": "#fcc383"
        },
        {
          "name": "sun-red",
          "hex": "#ff6b63"
        },
        {
          "name": "mint",
          "hex": "#cef5ca"
        },
        {
          "name": "pure-white",
          "hex": "#ffffff"
        },
        {
          "name": "success-mint",
          "hex": "#22c55e"
        }
      ]
    },
    "typography": {
      "sizes": [
        "text-xs",
        "text-sm",
        "text-base",
        "text-lg",
        "text-xl",
        "text-2xl",
        "text-3xl",
        "text-4xl",
        "text-5xl"
      ],
      "weights": [
        "font-normal",
        "font-medium",
        "font-semibold",
        "font-bold"
      ]
    },
    "motion": {
      "durations": [
        "duration-instant",
        "duration-fast",
        "duration-base",
        "duration-moderate",
        "duration-slow"
      ],
      "easings": [
        "ease-standard"
      ],
      "maxMs": 300
    },
    "shadows": {
      "validStandard": [
        "shadow-surface",
        "shadow-resting",
        "shadow-lifted",
        "shadow-raised",
        "shadow-floating",
        "shadow-focused",
        "shadow-inset",
        "shadow-btn",
        "shadow-btn-hover",
        "shadow-card",
        "shadow-card-lg",
        "shadow-inner"
      ],
      "validPixel": [
        "pixel-shadow-surface",
        "pixel-shadow-resting",
        "pixel-shadow-lifted",
        "pixel-shadow-raised",
        "pixel-shadow-floating"
      ],
      "validGlow": [
        "shadow-glow-sm",
        "shadow-glow-md",
        "shadow-glow-lg",
        "shadow-glow-xl",
        "shadow-glow-success",
        "shadow-glow-error",
        "shadow-glow-info"
      ]
    },
    "radius": {
      "pixelCorners": [
        "pixel-rounded-xs",
        "pixel-rounded-sm",
        "pixel-rounded-md",
        "pixel-rounded-lg",
        "pixel-rounded-xl",
        "pixel-corners"
      ]
    }
  },
  "components": [
    {
      "name": "Button",
      "replaces": [
        "<button>"
      ],
      "import": "@rdna/radiants/components/core"
    },
    {
      "name": "Card",
      "a11y": {
        "contrastRequirement": "AA"
      }
    },
    {
      "name": "Collapsible",
      "replaces": [
        "<details>",
        "<summary>"
      ],
      "import": "@rdna/radiants/components/core",
      "wraps": "@base-ui/react/collapsible"
    },
    {
      "name": "Dialog",
      "replaces": [
        "<dialog>"
      ],
      "import": "@rdna/radiants/components/core"
    },
    {
      "name": "Input",
      "replaces": [
        "<input>"
      ],
      "import": "@rdna/radiants/components/core"
    },
    {
      "name": "Meter",
      "replaces": [
        "<meter>",
        "<progress>"
      ],
      "import": "@rdna/radiants/components/core",
      "wraps": "@base-ui/react/meter",
      "a11y": {
        "role": "meter",
        "contrastRequirement": "AA"
      }
    },
    {
      "name": "Select",
      "replaces": [
        "<select>"
      ],
      "import": "@rdna/radiants/components/core"
    },
    {
      "name": "Separator",
      "replaces": [
        "<hr>"
      ],
      "import": "@rdna/radiants/components/core",
      "wraps": "@base-ui/react/separator",
      "a11y": {
        "role": "separator",
        "requiredAttributes": [
          "aria-orientation"
        ]
      }
    },
    {
      "name": "TextArea",
      "replaces": [
        "<textarea>"
      ],
      "import": "@rdna/radiants/components/core"
    },
    {
      "name": "Toggle",
      "wraps": "@base-ui/react/toggle",
      "a11y": {
        "role": "button",
        "requiredAttributes": [
          "aria-pressed"
        ],
        "keyboardInteractions": [
          "Enter",
          "Space"
        ]
      }
    }
  ],
  "elementReplacements": {
    "button": "Button",
    "details": "Collapsible",
    "summary": "Collapsible",
    "dialog": "Dialog",
    "input": "Input",
    "meter": "Meter",
    "progress": "Meter",
    "select": "Select",
    "hr": "Separator",
    "textarea": "TextArea"
  }
}
