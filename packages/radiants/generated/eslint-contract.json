{
  "$schema": "./eslint-contract.schema.json",
  "contractVersion": "0.1.0",
  "tokenMap": {
    "brandPalette": {
      "#fef8e2": "cream",
      "#0f0e0c": "ink",
      "#000000": "pure-black",
      "#fce184": "sun-yellow",
      "#95bad2": "sky-blue",
