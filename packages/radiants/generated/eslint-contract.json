      "#ff6b63": "sun-red",
      "#cef5ca": "mint",
      "#fffcf3": "pure-white",
      "#22c55e": "success-mint"
    },
    "hexToSemantic": {
      "#fef8e2": {
        "bg": "page",
        "text": "flip"
      },
      "#0f0e0c": {
        "bg": "inv",
        "text": "main",
        "border": "line"
      },
      "#95bad2": {
        "text": "link"
      },
      "#ff6b63": {
        "bg": "danger",
        "text": "danger"
      },
      "#cef5ca": {
        "bg": "success",
        "text": "success"
      },
      "#fffcf3": {
        "bg": "card"
      },
      "#22c55e": {
        "text": "success"
      }
    },
    "oklchToSemantic": {
      "oklch(0.9780 0.0295 94.34)": {
        "bg": "page",
        "text": "flip"
      },
      "oklch(0.1641 0.0044 84.59)": {
        "bg": "inv",
        "text": "main",
