{
  "$description": "Primitive RDNA Radiants shape and layout tokens generated from packages/radiants/tokens.css.",
  "radius": {
    "none": {
      "$type": "borderRadius",
      "$value": "0"
    },
    "xs": {
      "$type": "borderRadius",
      "$value": "0.125rem"
    },
    "sm": {
      "$type": "borderRadius",
      "$value": "0.25rem"
    },
    "md": {
      "$type": "borderRadius",
      "$value": "0.5rem"
    },
    "lg": {
      "$type": "borderRadius",
      "$value": "1rem"
    },
    "full": {
      "$type": "borderRadius",
      "$value": "9999px"
    }
  },
  "shadow": {
    "glow-sm": {
      "$type": "shadow",
      "$value": "2px 2px 0 0 var(--color-ink)"
    },
    "glow-md": {
      "$type": "shadow",
      "$value": "3px 3px 0 0 var(--color-ink)"
    },
    "glow-lg": {
      "$type": "shadow",
      "$value": "4px 4px 0 0 var(--color-ink)"
    },
    "glow-xl": {
      "$type": "shadow",
      "$value": "5px 5px 0 0 var(--color-ink)"
    },
    "glow-success": {
      "$type": "shadow",
      "$value": "2px 2px 0 0 var(--color-mint)"
    },
    "glow-error": {
      "$type": "shadow",
      "$value": "2px 2px 0 0 var(--color-sun-red)"
    },
    "glow-info": {
      "$type": "shadow",
      "$value": "2px 2px 0 0 var(--color-sky-blue)"
    },
    "inset": {
      "$type": "shadow",
      "$value": "inset 0 0 0 1px var(--color-ink)"
    },
    "surface": {
      "$type": "shadow",
      "$value": "0 1px 0 0 var(--color-ink)"
    },
    "resting": {
      "$type": "shadow",
      "$value": "0 2px 0 0 var(--color-ink)"
    },
    "lifted": {
      "$type": "shadow",
      "$value": "0 4px 0 0 var(--color-ink)"
    },
    "raised": {
      "$type": "shadow",
      "$value": "2px 2px 0 0 var(--color-ink)"
    },
    "floating": {
      "$type": "shadow",
      "$value": "4px 4px 0 0 var(--color-ink)"
    },
    "focused": {
      "$type": "shadow",
      "$value": "0 0 0 2px oklch(0.9126 0.1170 93.68 / 0.35), 0 0 8px 3px oklch(0.9126 0.1170 93.68 / 0.18)"
    }
  },
  "focusRing": {
    "width": {
      "$type": "dimension",
      "$value": "2px"
    },
    "offset": {
      "$type": "dimension",
      "$value": "2px"
    },
    "color": {
      "$type": "color",
      "$value": "{color.sun-yellow}"
    }
  },
  "touchTarget": {
    "min": {
      "$type": "dimension",
      "$value": "44px"
    },
    "comfortable": {
      "$type": "dimension",
      "$value": "48px"
    },
    "default": {
      "$type": "dimension",
      "$value": "{touchTarget.comfortable}"
    }
  },
  "breakpoint": {
    "xs": {
      "$type": "dimension",
      "$value": "360px"
    }
  },
  "zIndex": {
    "base": {
      "$type": "number",
      "$value": "0"
    },
    "desktop": {
      "$type": "number",
      "$value": "10"
    },
    "windows": {
      "$type": "number",
      "$value": "100"
    },
    "chrome": {
      "$type": "number",
      "$value": "200"
    },
    "menus": {
      "$type": "number",
      "$value": "300"
    },
    "toasts": {
      "$type": "number",
      "$value": "400"
    },
    "modals": {
      "$type": "number",
      "$value": "500"
    },
    "system": {
      "$type": "number",
      "$value": "900"
    }
  }
}
