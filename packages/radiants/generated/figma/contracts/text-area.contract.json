{
  "id": "text-area",
  "name": "TextArea",
  "description": "Multi-line text input with semantic token styling. Shares visual language with Input.",
  "sourcePath": "packages/radiants/components/core/Input/Input.tsx",
  "schemaPath": "packages/radiants/components/core/Input/TextArea.schema.json",
  "importPath": "@rdna/radiants/components/core",
  "platforms": [
    "web"
  ],
  "category": "form",
  "renderMode": "custom",
  "tags": [
    "text",
    "multiline",
    "textarea"
  ],
  "props": {
    "error": {
      "type": "boolean",
      "default": false,
      "description": "Shows error state styling"
    },
    "fullWidth": {
      "type": "boolean",
      "default": false,
      "description": "Makes textarea take full container width"
    },
    "disabled": {
      "type": "boolean",
      "default": false,
      "description": "Disables the textarea"
    },
    "placeholder": {
      "type": "string",
      "description": "Placeholder text"
    },
    "rows": {
      "type": "number",
      "description": "Visible number of text lines"
    }
  },
  "slots": {},
  "subcomponents": [],
  "states": [
    {
      "name": "focus",
      "driver": "wrapper"
    },
    {
      "name": "error",
      "driver": "wrapper"
    },
    {
      "name": "disabled",
      "driver": "prop",
      "prop": "disabled",
      "value": true
    }
  ],
  "variants": [],
  "exampleProps": {},
  "controlledProps": [],
  "examples": [
    {
      "name": "Basic textarea",
      "code": "<TextArea placeholder=\"Write a message...\" />"
    },
    {
      "name": "With label (Input.Root)",
      "code": "<Input.Root>\n  <Input.Label>Message</Input.Label>\n  <TextArea placeholder=\"Your message here\" />\n</Input.Root>"
    }
  ],
  "tokens": {
    "color": {
      "default.background": "page",
      "default.text": "main",
      "default.border": "line",
      "default.placeholder": "mute",
      "default.focusRing": "focus",
      "error.border": "danger",
      "error.focusRing": "danger"
    }
  },
  "tokenBindings": {
    "default": {
      "background": "page",
      "text": "main",
      "border": "line",
      "placeholder": "mute",
      "focusRing": "focus"
    },
    "error": {
      "border": "danger",
      "focusRing": "danger"
    }
  },
  "replaces": [
    {
      "element": "textarea",
      "import": "@rdna/radiants/components/core"
    }
  ],
  "pixelCorners": false,
  "shadowSystem": null,
  "styleOwnership": [],
  "structuralRules": [],
  "wraps": null,
  "a11y": null
}
