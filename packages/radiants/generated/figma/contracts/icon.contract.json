{
  "id": "icon",
  "name": "Icon",
  "description": "Bitmap-backed RDNA icon wrapper with dual-size support. Renders baked 16px or 24px icons through @rdna/pixel BitmapIcon. Public size contract is 16 or 24 only.",
  "sourcePath": "packages/radiants/components/core/Icon/Icon.tsx",
  "schemaPath": "packages/radiants/components/core/Icon/Icon.schema.json",
  "importPath": "@rdna/radiants/components/core",
  "platforms": [
    "web"
  ],
  "category": "media",
  "renderMode": "custom",
  "tags": [
    "icon",
    "bitmap",
    "16px",
    "24px",
    "pixel-art"
  ],
  "props": {
    "name": {
      "type": "string",
      "description": "Canonical icon name or alias resolved against the baked bitmap registries. Aliases like 'search', 'home', and 'trash' resolve automatically."
    },
    "size": {
      "type": "enum",
      "values": [
        16,
        24
      ],
      "default": 16,
      "description": "Render size: 16 or 24 only. `size={24}` and `large` both select the 24px bitmap registry."
    },
    "large": {
      "type": "boolean",
      "default": false,
      "description": "When true, selects the 24px bitmap registry. Equivalent to `size={24}`."
    },
    "className": {
      "type": "string",
      "default": "",
      "description": "CSS classes for styling. Use text-* classes for color."
    }
  },
  "slots": {},
  "subcomponents": [],
  "states": [],
  "variants": [],
  "exampleProps": {},
  "controlledProps": [],
  "examples": [
    {
      "name": "16px bitmap (default)",
      "code": "<Icon name=\"search\" />"
    },
    {
      "name": "24px bitmap via size",
      "code": "<Icon name=\"search\" size={24} />"
    },
    {
      "name": "24px-only icon via large",
      "code": "<Icon name=\"coding-apps-websites-database\" large />"
    }
  ],
  "tokens": {
    "color": {
      "base.text": "currentColor"
    }
  },
  "tokenBindings": {
    "base": {
      "text": "currentColor"
    }
  },
  "replaces": [],
  "pixelCorners": false,
  "shadowSystem": null,
  "styleOwnership": [],
  "structuralRules": [],
  "wraps": null,
  "a11y": null
}
