{
  "id": "avatar",
  "name": "Avatar",
  "description": "User profile image with automatic fallback to initials when the image is unavailable or not provided.",
  "sourcePath": "packages/radiants/components/core/Avatar/Avatar.tsx",
  "schemaPath": "packages/radiants/components/core/Avatar/Avatar.schema.json",
  "importPath": "@rdna/radiants/components/core",
  "platforms": [
    "web"
  ],
  "category": "data-display",
  "renderMode": "custom",
  "tags": [
    "avatar",
    "user",
    "image",
    "profile"
  ],
  "props": {
    "src": {
      "type": "string",
      "description": "URL of the avatar image. Falls back to initials when omitted or fails to load."
    },
    "alt": {
      "type": "string",
      "default": "",
      "description": "Accessible alt text for the avatar image"
    },
    "fallback": {
      "type": "string",
      "default": "",
      "description": "Initials or short text shown when the image is unavailable"
    },
    "size": {
      "type": "enum",
      "values": [
        "sm",
        "md",
        "lg",
        "xl"
      ],
      "default": "md",
      "description": "Size preset controlling width, height, and text size"
    },
    "shape": {
      "type": "enum",
      "values": [
        "circle",
        "square"
      ],
      "default": "circle",
      "description": "Border-radius shape of the avatar"
    }
  },
  "slots": {},
  "subcomponents": [],
  "states": [],
  "variants": [],
  "exampleProps": {},
  "controlledProps": [],
  "examples": [
    {
      "name": "Image avatar",
      "code": "<Avatar src=\"/avatars/user.jpg\" alt=\"Jane Doe\" />"
    },
    {
      "name": "Fallback initials",
      "code": "<Avatar fallback=\"JD\" />"
    },
    {
      "name": "Large square",
      "code": "<Avatar src=\"/avatars/user.jpg\" alt=\"Jane Doe\" size=\"lg\" shape=\"square\" />"
    }
  ],
  "tokens": {
    "color": {
      "base.border": "line",
      "fallback.background": "tinted",
      "fallback.text": "main"
    },
    "typography": {
      "fallback.font": "monospace"
    },
    "misc": {
      "image.objectFit": "cover"
    }
  },
  "tokenBindings": {
    "base": {
      "border": "line"
    },
    "image": {
      "objectFit": "cover"
    },
    "fallback": {
      "background": "tinted",
      "text": "main",
      "font": "monospace"
    }
  },
  "replaces": [],
  "pixelCorners": false,
  "shadowSystem": null,
  "styleOwnership": [],
  "structuralRules": [],
  "wraps": null,
  "a11y": null
}
