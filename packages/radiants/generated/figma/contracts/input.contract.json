{
  "id": "input",
  "name": "Input",
  "description": "Text input with semantic token styling. Works standalone or as a compound component with Input.Root for accessible form fields with labels, descriptions, and validation.",
  "sourcePath": "packages/radiants/components/core/Input/Input.tsx",
  "schemaPath": "packages/radiants/components/core/Input/Input.schema.json",
  "importPath": "@rdna/radiants/components/core",
  "platforms": [
    "web"
  ],
  "category": "form",
  "renderMode": "custom",
  "tags": [
    "text",
    "field",
    "form",
    "input",
    "label",
    "validation"
  ],
  "props": {
    "size": {
      "type": "enum",
      "values": [
        "sm",
        "md",
        "lg"
      ],
      "default": "md",
      "description": "Size preset for input height and padding"
    },
    "error": {
      "type": "boolean",
      "default": false,
      "description": "Shows error state styling (standalone mode only)"
    },
    "fullWidth": {
      "type": "boolean",
      "default": false,
      "description": "Makes input take full container width"
    },
    "iconName": {
      "type": "string",
      "description": "Icon name for leading icon slot"
    },
    "disabled": {
      "type": "boolean",
      "default": false,
      "description": "Disables the input"
    }
  },
  "slots": {
    "icon": {
      "description": "Leading icon slot"
    },
    "Root": {
      "description": "Accessible form field wrapper (Base UI Field.Root)"
    },
    "Label": {
      "description": "Auto-wired label with optional required indicator"
    },
    "Description": {
      "description": "Help text displayed below the control"
    },
    "Error": {
      "description": "Error message displayed when the field is invalid"
    },
    "Validity": {
      "description": "Render prop exposing native validity state"
    }
  },
  "subcomponents": [
    "Input.Root",
    "Input.Label",
    "Input.Description",
    "Input.Error",
    "Input.Validity"
  ],
  "states": [
    {
      "name": "focus",
      "driver": "wrapper"
    },
    {
      "name": "error",
      "driver": "wrapper"
    },
    {
      "name": "disabled",
      "driver": "prop",
      "prop": "disabled",
      "value": true
    }
  ],
  "variants": [],
  "exampleProps": {
    "placeholder": "Type something..."
  },
  "controlledProps": [],
  "examples": [
    {
      "name": "Standalone input",
      "code": "<Input placeholder=\"Search...\" size=\"sm\" />"
    },
    {
      "name": "Accessible form field",
      "code": "<Input.Root>\n  <Input.Label required>Email</Input.Label>\n  <Input type=\"email\" placeholder=\"you@example.com\" />\n  <Input.Description>We'll never share your email.</Input.Description>\n  <Input.Error>Enter a valid email.</Input.Error>\n</Input.Root>"
    },
    {
      "name": "TextArea inside Root",
      "code": "<Input.Root>\n  <Input.Label>Message</Input.Label>\n  <TextArea placeholder=\"Write a message...\" />\n</Input.Root>"
    }
  ],
  "tokens": {
    "color": {
      "default.background": "page",
      "default.text": "main",
      "default.border": "line",
      "default.placeholder": "mute",
      "default.focusRing": "focus",
      "default.label": "main",
      "default.description": "mute",
      "error.border": "danger",
      "error.focusRing": "danger",
      "error.errorText": "danger"
    }
  },
  "tokenBindings": {
    "default": {
      "background": "page",
      "text": "main",
      "border": "line",
      "placeholder": "mute",
      "focusRing": "focus",
      "label": "main",
      "description": "mute"
    },
    "error": {
      "border": "danger",
      "focusRing": "danger",
      "errorText": "danger"
    }
  },
  "replaces": [
    {
      "element": "input",
      "import": "@rdna/radiants/components/core",
      "note": "Text-like inputs only in v1"
    }
  ],
  "pixelCorners": false,
  "shadowSystem": null,
  "styleOwnership": [],
  "structuralRules": [],
  "wraps": null,
  "a11y": null
}
