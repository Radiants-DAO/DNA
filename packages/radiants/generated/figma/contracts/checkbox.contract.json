{
  "id": "checkbox",
  "name": "Checkbox",
  "description": "Retro-styled checkbox and radio components for form selections. Provides accessible input controls with visual feedback states.",
  "sourcePath": "packages/radiants/components/core/Checkbox/Checkbox.tsx",
  "schemaPath": "packages/radiants/components/core/Checkbox/Checkbox.schema.json",
  "importPath": "@rdna/radiants/components/core",
  "platforms": [
    "web"
  ],
  "category": "form",
  "renderMode": "inline",
  "tags": [
    "toggle",
    "check",
    "boolean"
  ],
  "props": {
    "label": {
      "type": "string",
      "description": "Label text displayed next to the input"
    },
    "disabled": {
      "type": "boolean",
      "default": false,
      "description": "Disable input interactions"
    },
    "checked": {
      "type": "boolean",
      "description": "Controlled checked state (native HTML attribute)"
    },
    "defaultChecked": {
      "type": "boolean",
      "description": "Initial checked state for uncontrolled usage"
    },
    "name": {
      "type": "string",
      "description": "Input name for form submission"
    },
    "value": {
      "type": "string",
      "description": "Input value for form submission"
    }
  },
  "slots": {},
  "subcomponents": [
    "Checkbox",
    "Radio"
  ],
  "states": [
    {
      "name": "hover",
      "driver": "wrapper"
    },
    {
      "name": "focus",
      "driver": "wrapper"
    },
    {
      "name": "disabled",
      "driver": "prop",
      "prop": "disabled",
      "value": true
    }
  ],
  "variants": [],
  "exampleProps": {
    "label": "Accept terms"
  },
  "controlledProps": [],
  "examples": [
    {
      "name": "Basic checkbox",
      "code": "<Checkbox label=\"Accept terms\" />"
    },
    {
      "name": "Checked checkbox",
      "code": "<Checkbox label=\"Subscribe to newsletter\" defaultChecked />"
    },
    {
      "name": "Disabled checkbox",
      "code": "<Checkbox label=\"Locked option\" disabled />"
    }
  ],
  "tokens": {
    "color": {
      "input.background": "page",
      "input.border": "line",
      "input.backgroundChecked": "accent",
      "input.focusRing": "focus",
      "checkmark.color": "main",
      "radioDot.background": "main",
      "label.text": "main"
    },
    "spacing": {
      "container.gap": "spacing-xs"
    },
    "typography": {
      "label.font": "mondwest"
    }
  },
  "tokenBindings": {
    "container": {
      "gap": "spacing-xs"
    },
    "input": {
      "background": "page",
      "border": "line",
      "backgroundChecked": "accent",
      "focusRing": "focus"
    },
    "checkmark": {
      "color": "main"
    },
    "radioDot": {
      "background": "main"
    },
    "label": {
      "text": "main",
      "font": "mondwest"
    }
  },
  "replaces": [],
  "pixelCorners": false,
  "shadowSystem": null,
  "styleOwnership": [],
  "structuralRules": [],
  "wraps": null,
  "a11y": null
}
