{
  "component": "Alert",
  "tokenBindings": {
    "base": {
      "padding": "spacing-md",
      "gap": "spacing-sm",
      "font": "body",
      "titleFont": "heading",
      "borderWidth": "2px",
      "borderRadius": "sm"
    },
    "default": {
      "background": "page",
      "text": "main",
      "border": "line"
    },
    "success": {
      "background": "success/10",
      "text": "main",
      "border": "success"
    },
    "warning": {
      "background": "warning/10",
      "text": "main",
      "border": "warning"
    },
    "error": {
      "background": "danger/10",
      "text": "main",
      "border": "danger"
    },
    "info": {
      "background": "link/10",
      "text": "main",
      "border": "link"
    }
  }
}
