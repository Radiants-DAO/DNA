{
  "component": "Alert",
  "description": "Token bindings for Alert component variants",
  "tokenBindings": {
    "base": {
      "padding": "spacing-md",
      "gap": "spacing-sm",
      "font": "body",
      "titleFont": "heading",
      "borderWidth": "2px",
      "borderRadius": "sm"
    },
    "default": {
      "background": "page",
      "text": "main",
      "border": "line"
    },
    "success": {
      "background": "success/10",
      "text": "main",
      "border": "success"
    },
    "warning": {
      "background": "warning/10",
      "text": "main",
      "border": "warning"
    },
    "error": {
      "background": "danger/10",
      "text": "main",
      "border": "danger"
    },
    "info": {
      "background": "link/10",
      "text": "main",
      "border": "link"
    }
  },
  "elements": {
    "title": {
      "font": "heading",
      "fontSize": "xs",
      "textTransform": "uppercase",
      "marginBottom": "spacing-xs"
    },
    "content": {
      "font": "body",
      "fontSize": "base",
      "textOpacity": "80%"
    },
    "closeButton": {
      "textOpacity": "50%",
      "textHoverOpacity": "100%"
    }
  }
}
