{
  "component": "Slider",
  "description": "Token bindings for Slider component",
  "tokenBindings": {
    "label": {
      "text": "main",
      "font": "heading"
    },
    "value": {
      "text": "main/60",
      "font": "heading"
    },
    "track": {
      "background": "line/10",
      "border": "line",
      "focusRing": "focus"
    },
    "fill": {
      "background": "accent"
    },
    "thumb": {
      "background": "depth",
      "border": "line"
    }
  },
  "states": {
    "disabled": {
      "opacity": "50%",
      "cursor": "not-allowed"
    },
    "dragging": {
      "thumbScale": "110%"
    }
  },
  "sizes": {
    "sm": {
      "trackHeight": "0.25rem",
      "thumbSize": "0.75rem"
    },
    "md": {
      "trackHeight": "0.5rem",
      "thumbSize": "1rem"
    },
    "lg": {
      "trackHeight": "0.75rem",
      "thumbSize": "1.25rem"
    }
  }
}
