{
  "component": "ContextMenu",
  "description": "Token bindings for ContextMenu component",
  "tokenBindings": {
    "content": {
      "background": "surface-primary",
      "border": "edge-primary",
      "shadow": "edge-primary"
    },
    "item": {
      "text": "content-primary",
      "textDestructive": "status-error",
      "backgroundHover": "action-primary"
    },
    "separator": {
      "border": "edge-primary/20"
    }
  },
  "states": {
    "disabled": {
      "opacity": "50%",
      "cursor": "not-allowed"
    }
  }
}
