{
  "component": "ContextMenu",
  "description": "Token bindings for ContextMenu component",
  "tokenBindings": {
    "content": {
      "background": "page",
      "border": "line",
      "shadow": "line"
    },
    "item": {
      "text": "main",
      "textDestructive": "danger",
      "backgroundHover": "accent"
    },
    "separator": {
      "border": "line/20"
    }
  },
  "states": {
    "disabled": {
      "opacity": "50%",
      "cursor": "not-allowed"
    }
  }
}
