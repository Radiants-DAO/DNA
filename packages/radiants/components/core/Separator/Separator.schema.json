{
  "name": "Separator",
  "description": "Accessible separator element for visually dividing content. Renders with proper role=\"separator\" semantics via Base UI.",
  "props": {
    "orientation": {
      "type": "enum",
      "values": ["horizontal", "vertical"],
      "default": "horizontal",
      "description": "Direction of the separator line"
    },
    "className": {
      "type": "string",
      "description": "Additional CSS classes for customization"
    }
  },
  "slots": {},
  "examples": [
    {
      "name": "Horizontal separator",
      "code": "<Separator />"
    },
    {
      "name": "Vertical separator",
      "code": "<div className=\"flex h-8 items-center gap-4\">\n  <span>Left</span>\n  <Separator orientation=\"vertical\" />\n  <span>Right</span>\n</div>"
    },
    {
      "name": "Between sections",
      "code": "<div className=\"space-y-4\">\n  <p>Section 1</p>\n  <Separator />\n  <p>Section 2</p>\n</div>"
    }
  ]
}
