{
  "component": "Avatar",
  "description": "Token bindings for Avatar component variants",
  "tokenBindings": {
    "base": {
      "border": "edge-primary"
    },
    "image": {
      "objectFit": "cover"
    },
    "fallback": {
      "background": "surface-tertiary",
      "text": "content-primary",
      "font": "monospace"
    }
  },
  "sizes": {
    "sm": {
      "width": "24px",
      "height": "24px",
      "fontSize": "xs"
    },
    "md": {
      "width": "32px",
      "height": "32px",
      "fontSize": "sm"
    },
    "lg": {
      "width": "40px",
      "height": "40px",
      "fontSize": "base"
    },
    "xl": {
      "width": "56px",
      "height": "56px",
      "fontSize": "lg"
    }
  },
  "shapes": {
    "circle": {
      "borderRadius": "full"
    },
    "square": {
      "borderRadius": "xs"
    }
  }
}
