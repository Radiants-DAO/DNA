{
  "name": "Spinner",
  "description": "Animated loader with two variants: PixelCode frames (default) or loading dots with text.",
  "props": {
    "variant": {
      "type": "enum",
      "values": ["default", "dots"],
      "default": "default",
      "description": "Visual variant — default (PixelCode frames) or dots (3 pixelated dots with LOADING text)"
    },
    "size": {
      "type": "number",
      "default": 24,
      "description": "Size in pixels"
    },
    "completed": {
      "type": "boolean",
      "default": false,
      "description": "When true, shows completion state (checkmark or LOADED)"
    }
  },
  "slots": {},
  "examples": [
    {
      "name": "Default spinner",
      "code": "<Spinner />"
    },
    {
      "name": "Loading dots",
      "code": "<Spinner variant=\"dots\" />"
    },
    {
      "name": "Loading dots (completed)",
      "code": "<Spinner variant=\"dots\" completed />"
    },
    {
      "name": "Large spinner",
      "code": "<Spinner size={48} />"
    },
    {
      "name": "Completed state",
      "code": "<Spinner completed />"
    }
  ]
}
