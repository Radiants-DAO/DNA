{
  "name": "Menubar",
  "description": "Horizontal menu bar with dropdown menus (File, Edit, View pattern). Provides accessible keyboard navigation between menu triggers and items. Ideal for desktop application UIs.",
  "subcomponents": [
    "Menubar.Root",
    "Menubar.Menu",
    "Menubar.Trigger",
    "Menubar.Content",
    "Menubar.Item",
    "Menubar.Separator",
    "Menubar.Label"
  ],
  "props": {
    "modal": {
      "type": "boolean",
      "default": false,
      "description": "Whether the menubar is modal"
    },
    "orientation": {
      "type": "enum",
      "values": ["horizontal", "vertical"],
      "default": "horizontal",
      "description": "Orientation of the menubar"
    }
  },
  "slots": {
    "children": {
      "description": "Menubar.Menu components, each containing a Menubar.Trigger and Menubar.Content"
    }
  },
  "examples": [
    {
      "name": "Basic menubar",
      "code": "<Menubar.Root>\n  <Menubar.Menu>\n    <Menubar.Trigger>File</Menubar.Trigger>\n    <Menubar.Content>\n      <Menubar.Item onClick={() => {}}>New</Menubar.Item>\n      <Menubar.Item onClick={() => {}}>Open</Menubar.Item>\n      <Menubar.Separator />\n      <Menubar.Item onClick={() => {}}>Exit</Menubar.Item>\n    </Menubar.Content>\n  </Menubar.Menu>\n  <Menubar.Menu>\n    <Menubar.Trigger>Edit</Menubar.Trigger>\n    <Menubar.Content>\n      <Menubar.Item onClick={() => {}}>Undo</Menubar.Item>\n      <Menubar.Item onClick={() => {}}>Redo</Menubar.Item>\n    </Menubar.Content>\n  </Menubar.Menu>\n</Menubar.Root>"
    },
    {
      "name": "With keyboard shortcuts",
      "code": "<Menubar.Root>\n  <Menubar.Menu>\n    <Menubar.Trigger>File</Menubar.Trigger>\n    <Menubar.Content>\n      <Menubar.Item shortcut=\"Ctrl+N\">New</Menubar.Item>\n      <Menubar.Item shortcut=\"Ctrl+O\">Open</Menubar.Item>\n      <Menubar.Item shortcut=\"Ctrl+S\">Save</Menubar.Item>\n    </Menubar.Content>\n  </Menubar.Menu>\n</Menubar.Root>"
    }
  ]
}
