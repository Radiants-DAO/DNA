{
  "component": "Toast",
  "tokenBindings": {
    "default": {
      "background": "page",
      "text": "main",
      "border": "line",
      "shadow": "shadow-raised"
    },
    "success": {
      "background": "success",
      "text": "main",
      "border": "success"
    },
    "warning": {
      "background": "warning",
      "text": "main",
      "border": "tinted"
    },
    "error": {
      "background": "danger",
      "text": "main",
      "border": "danger"
    },
    "info": {
      "background": "link",
      "text": "main",
      "border": "link"
    }
  }
}
