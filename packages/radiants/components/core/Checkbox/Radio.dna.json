{
  "component": "Radio",
  "description": "Token bindings for Radio component",
  "tokenBindings": {
    "container": {
      "gap": "spacing-xs"
    },
    "input": {
      "background": "page",
      "border": "line",
      "backgroundChecked": "accent",
      "focusRing": "focus"
    },
    "dot": {
      "background": "main"
    },
    "label": {
      "text": "main",
      "font": "mondwest"
    }
  },
  "states": {
    "disabled": {
      "opacity": "50%",
      "cursor": "not-allowed"
    },
    "checked": {
      "background": "accent"
    },
    "focus": {
      "ring": "focus",
      "ringOffset": "1px"
    }
  }
}
