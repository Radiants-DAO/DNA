{
  "component": "Radio",
  "description": "Token bindings for Radio component",
  "tokenBindings": {
    "container": {
      "gap": "spacing-xs"
    },
    "input": {
      "background": "surface-primary",
      "border": "edge-primary",
      "backgroundChecked": "action-primary",
      "focusRing": "edge-focus"
    },
    "dot": {
      "background": "content-primary"
    },
    "label": {
      "text": "content-primary",
      "font": "mondwest"
    }
  },
  "states": {
    "disabled": {
      "opacity": "50%",
      "cursor": "not-allowed"
    },
    "checked": {
      "background": "action-primary"
    },
    "focus": {
      "ring": "edge-focus",
      "ringOffset": "1px"
    }
  }
}
