{
  "component": "Toolbar",
  "description": "Token bindings for the Toolbar component",
  "tokenBindings": {
    "root": {
      "background": "inv",
      "border": "line"
    },
    "button": {
      "text": "main",
      "backgroundHover": "page",
      "backgroundActive": "accent",
      "textActive": "flip",
      "focusRing": "focus"
    },
    "separator": {
      "background": "line"
    },
    "link": {
      "text": "main",
      "backgroundHover": "page",
      "focusRing": "focus"
    }
  },
  "states": {
    "disabled": {
      "opacity": "50%",
      "cursor": "not-allowed"
    },
    "focus": {
      "ring": "focus",
      "ringOffset": "1px"
    },
    "active": {
      "background": "accent",
      "text": "flip"
    }
  }
}
