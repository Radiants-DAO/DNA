{
  "component": "Select",
  "description": "Token bindings for Select component",
  "tokenBindings": {
    "trigger": {
      "background": "page",
      "text": "main",
      "textPlaceholder": "main/40",
      "border": "line",
      "borderError": "danger",
      "shadow": "line",
      "focusRing": "focus"
    },
    "dropdown": {
      "background": "page",
      "border": "line",
      "shadow": "line"
    },
    "option": {
      "text": "main",
      "backgroundSelected": "accent",
      "backgroundHover": "accent"
    }
  },
  "states": {
    "disabled": {
      "opacity": "50%",
      "cursor": "not-allowed"
    },
    "open": {
      "shadowOffset": "3px",
      "transform": "translateY(-0.125rem)"
    },
    "closed": {
      "shadowOffset": "1px"
    },
    "optionDisabled": {
      "opacity": "50%",
      "cursor": "not-allowed"
    }
  }
}
