{
  "name": "Label",
  "description": "Form label with optional required indicator asterisk.",
  "props": {
    "children": {
      "type": "node",
      "required": true,
      "description": "Label text content"
    },
    "required": {
      "type": "boolean",
      "default": false,
      "description": "Shows a red asterisk after the label"
    },
    "htmlFor": {
      "type": "string",
      "description": "Associates the label with a form control by id"
    }
  },
  "slots": {},
  "examples": [
    {
      "name": "Basic label",
      "code": "<Label htmlFor=\"email\">Email</Label>"
    },
    {
      "name": "Required label",
      "code": "<Label htmlFor=\"name\" required>Full Name</Label>"
    }
  ]
}
