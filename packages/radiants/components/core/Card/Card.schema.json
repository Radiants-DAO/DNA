{
  "name": "Card",
  "description": "Container with retro pixel-corner bevels and theme-owned colors",
  "props": {
    "variant": {
      "type": "enum",
      "values": ["default", "inverted", "raised"],
      "default": "default",
      "description": "Visual variant controlling background and bevel treatment"
    },
    "rounded": {
      "type": "enum",
      "values": ["sm", "md", "lg"],
      "default": "lg",
      "description": "Pixel-corner roundness"
    },
    "className": {
      "type": "string",
      "description": "Additional CSS classes to apply"
    }
  },
  "slots": ["children"],
  "subcomponents": ["CardHeader", "CardBody", "CardFooter"]
}
