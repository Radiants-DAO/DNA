{
  "component": "Breadcrumbs",
  "description": "Token bindings for Breadcrumbs navigation component",
  "tokenBindings": {
    "base": {
      "font": "heading",
      "gap": "spacing-sm"
    },
    "separator": {
      "text": "content-primary/40"
    },
    "link": {
      "text": "content-primary/60",
      "textHover": "content-primary"
    },
    "current": {
      "text": "content-primary",
      "fontWeight": "semibold"
    },
    "inactive": {
      "text": "content-primary/60"
    }
  },
  "states": {
    "hover": {
      "textDecoration": "underline"
    }
  }
}
