{
  "component": "ToggleGroup",
  "description": "Token bindings for the ToggleGroup component",
  "tokenBindings": {
    "root": {
      "border": "edge-primary"
    },
    "item": {
      "background": "surface-primary",
      "backgroundPressed": "action-primary",
      "text": "content-primary",
      "textPressed": "content-inverted",
      "border": "edge-primary",
      "focusRing": "edge-focus"
    }
  },
  "states": {
    "pressed": {
      "background": "action-primary",
      "text": "content-inverted"
    },
    "disabled": {
      "opacity": "50%",
      "cursor": "not-allowed"
    },
    "focus": {
      "ring": "edge-focus",
      "ringOffset": "1px"
    },
    "hover": {
      "background": "surface-secondary"
    }
  }
}
