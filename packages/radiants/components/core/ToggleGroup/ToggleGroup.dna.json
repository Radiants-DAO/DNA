{
  "component": "ToggleGroup",
  "description": "Token bindings for the ToggleGroup component",
  "tokenBindings": {
    "root": {
      "border": "line"
    },
    "item": {
      "background": "page",
      "backgroundPressed": "accent",
      "text": "main",
      "textPressed": "flip",
      "border": "line",
      "focusRing": "focus"
    }
  },
  "states": {
    "pressed": {
      "background": "accent",
      "text": "flip"
    },
    "disabled": {
      "opacity": "50%",
      "cursor": "not-allowed"
    },
    "focus": {
      "ring": "focus",
      "ringOffset": "1px"
    },
    "hover": {
      "background": "inv"
    }
  }
}
