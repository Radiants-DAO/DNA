{
  "component": "PreviewCard",
  "description": "Token bindings for PreviewCard component",
  "tokenBindings": {
    "trigger": {
      "focusRing": "edge-focus"
    },
    "content": {
      "background": "surface-elevated",
      "border": "edge-primary",
      "borderRadius": "xs",
      "shadow": "sm"
    }
  },
  "animation": {
    "duration": "150ms",
    "easing": "ease-out",
    "enterFrom": "opacity-0 translate-y-1",
    "exitTo": "opacity-0 blur-sm"
  }
}
