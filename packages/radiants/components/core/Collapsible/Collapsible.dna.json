{
  "component": "Collapsible",
  "description": "Token bindings for Collapsible component",
  "tokenBindings": {
    "trigger": {
      "text": "main",
      "border": "line",
      "hoverBackground": "hover"
    },
    "content": {
      "text": "main"
    }
  },
  "states": {
    "disabled": {
      "opacity": "50%",
      "cursor": "not-allowed"
    },
    "focus": {
      "ring": "focus",
      "ringOffset": "1px"
    }
  }
}
