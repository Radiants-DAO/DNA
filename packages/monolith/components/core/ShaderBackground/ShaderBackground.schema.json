{
  "name": "ShaderBackground",
  "description": "Animated dithering shader background using @paper-design/shaders-react with responsive mobile handling",
  "props": {
    "initialSettings": {
      "type": "object",
      "properties": {
        "colorBack": { "type": "string", "description": "Background color (hex)" },
        "colorFront": { "type": "string", "description": "Foreground/dither color (hex)" },
        "shape": {
          "type": "enum",
          "values": ["sphere", "wave", "dots", "ripple", "swirl", "warp"]
        },
        "type": {
          "type": "enum",
          "values": ["2x2", "4x4", "8x8", "random"]
        },
        "size": { "type": "number" },
        "speed": { "type": "number" },
        "scale": { "type": "number" },
        "rotation": { "type": "number" },
        "offsetX": { "type": "number" },
        "offsetY": { "type": "number" }
      },
      "description": "Initial shader settings (animation start state)"
    },
    "finalSettings": {
      "type": "object",
      "description": "Final shader settings (animation end state)"
    },
    "mobileSettings": {
      "type": "object",
      "description": "Mobile-specific static settings (no animation)"
    },
    "animationDelay": {
      "type": "number",
      "default": 500,
      "description": "Delay before animation starts (ms)"
    },
    "animationDuration": {
      "type": "number",
      "default": 15000,
      "description": "Animation duration (ms)"
    },
    "mobileBreakpoint": {
      "type": "number",
      "default": 768,
      "description": "Breakpoint for mobile detection (px)"
    },
    "mobileOpacity": {
      "type": "number",
      "default": 0.26,
      "description": "Static opacity on mobile devices"
    },
    "animated": {
      "type": "boolean",
      "default": true,
      "description": "Enable/disable entrance animation"
    },
    "className": {
      "type": "string",
      "default": "",
      "description": "Additional CSS classes"
    }
  },
  "examples": [
    {
      "name": "Default shader background",
      "code": "<ShaderBackground />"
    },
    {
      "name": "Custom colors",
      "code": "<ShaderBackground\n  initialSettings={{\n    colorFront: '#ef5c6f',\n    shape: 'ripple'\n  }}\n/>"
    },
    {
      "name": "Static (no animation)",
      "code": "<ShaderBackground animated={false} />"
    },
    {
      "name": "Fast animation",
      "code": "<ShaderBackground\n  animationDelay={0}\n  animationDuration={5000}\n/>"
    }
  ]
}
