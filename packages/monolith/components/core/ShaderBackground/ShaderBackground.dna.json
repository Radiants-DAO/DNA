{
  "component": "ShaderBackground",
  "description": "Token bindings for dithering shader background effect",
  "tokenBindings": {
    "container": {
      "position": "fixed",
      "inset": "0",
      "zIndex": "-1",
      "pointerEvents": "none",
      "overflow": "hidden"
    },
    "colors": {
      "colorBack": "page",
      "colorFront": "inv"
    }
  },
  "defaults": {
    "desktop": {
      "shape": "swirl",
      "type": "8x8",
      "size": 1.8,
      "speed": 0.58,
      "scale": {
        "initial": 0.1,
        "final": 3.48
      },
      "rotation": 360
    },
    "mobile": {
      "shape": "warp",
      "type": "8x8",
      "size": 1.4,
      "speed": 0.58,
      "scale": 3.48,
      "rotation": 360,
      "opacity": 0.26
    }
  },
  "animation": {
    "delay": "500ms",
    "duration": "15000ms",
    "easing": "ease-out-end",
    "property": "scale"
  },
  "themeColors": {
    "ultraviolet": "--color-ultraviolet",
    "magma": "--color-magma",
    "amber": "--color-amber",
    "green": "--color-green",
    "black": "--color-black"
  }
}
