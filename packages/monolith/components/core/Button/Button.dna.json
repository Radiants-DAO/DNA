{
  "component": "Button",
  "description": "Token bindings for Button component variants",
  "tokenBindings": {
    "base": {
      "border": "line",
      "borderRadius": "radius-sm",
      "font": "ui",
      "focusRing": "focus"
    },
    "primary": {
      "background": "accent",
      "text": "flip",
      "shadow": "btn",
      "hoverBackground": "accent-soft",
      "hoverShadow": "btn-hover"
    },
    "secondary": {
      "background": "accent-inv",
      "text": "main",
      "shadow": "btn",
      "hoverBackground": "card"
    },
    "outline": {
      "background": "transparent",
      "text": "main",
      "shadow": "btn"
    },
    "ghost": {
      "background": "transparent",
      "text": "main",
      "border": "transparent",
      "shadow": "none"
    },
    "mono": {
      "background": "gradient-accent",
      "text": "main",
      "borderTop": "bevel-highlight",
      "borderLeft": "bevel-highlight",
      "borderBottom": "bevel-shadow",
      "borderRight": "bevel-shadow",
      "shadow": "btn",
      "textShadow": "0 0 0.1rem rgba(255,255,255,0.3)",
      "hoverBackground": "gradient-action-hover",
      "hoverShadow": "0 0 2rem 0 var(--color-magma), 0 0.25rem 0 0 var(--color-black)",
      "activeBackground": "gradient-action-active",
      "activeBorderTop": "bevel-shadow",
      "activeBorderLeft": "bevel-shadow",
      "activeBorderBottom": "bevel-highlight",
      "activeBorderRight": "bevel-highlight"
    }
  },
  "states": {
    "hover": {
      "transform": "translateY(-2px)",
      "shadow": "btn-hover"
    },
    "active": {
      "transform": "translateY(2px)",
      "shadow": "btn-active"
    },
    "disabled": {
      "opacity": "50%",
      "cursor": "not-allowed",
      "transform": "none",
      "shadow": "none"
    },
    "loading": {
      "cursor": "wait"
    }
  }
}
