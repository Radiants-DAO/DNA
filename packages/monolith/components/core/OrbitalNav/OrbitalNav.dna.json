{
  "component": "OrbitalNav",
  "description": "Token bindings for OrbitalNav component",
  "tokenBindings": {
    "base": {
      "font": "ui"
    },
    "orbitalIcon": {
      "background": "card",
      "border": "line",
      "borderRadius": "radius-full",
      "shadow": "btn"
    },
    "orbitalIconActive": {
      "borderColor": "accent-soft"
    },
    "orbitalLabel": {
      "font": "mono",
      "text": "main",
      "background": "page"
    },
    "dataStream": {
      "font": "mono",
      "text": "sub"
    }
  },
  "glowColors": {
    "magma": "--color-magma",
    "ultraviolet": "--color-ultraviolet",
    "tangerine": "--color-tangerine"
  },
  "states": {
    "hover": {
      "iconGlow": "0 0 1.5em var(--icon-glow)",
      "streamOpacity": "1"
    },
    "active": {
      "borderColor": "accent-soft",
      "iconGlow": "0 0 2em var(--icon-glow)"
    },
    "dismiss": {
      "description": "Spiral inward animation when modal opens"
    },
    "return": {
      "description": "Staggered emergence when modal closes"
    }
  },
  "animation": {
    "orbitalSpeed": "0.065 rad/s",
    "spawnDelay": "1.2s",
    "spawnStagger": "0.15s",
    "dismissStagger": "0.08s",
    "returnStagger": "0.12s",
    "gravityRadius": "200px",
    "gravityPull": "25px"
  }
}
