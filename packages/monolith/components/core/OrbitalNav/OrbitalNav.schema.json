{
  "name": "OrbitalNav",
  "description": "Animated circular navigation with orbital motion, spiral dismiss animations, and data stream connections",
  "props": {
    "items": {
      "type": "array",
      "description": "Array of orbital navigation items",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the item"
          },
          "icon": {
            "type": "string",
            "description": "URL or path to the icon image"
          },
          "label": {
            "type": "string",
            "description": "Display label for the item"
          },
          "phaseOffset": {
            "type": "number",
            "description": "Initial angular position offset in radians"
          },
          "glowColor": {
            "type": "string",
            "description": "Hex color for the glow effect"
          },
          "iconScale": {
            "type": "number",
            "description": "Optional scale multiplier for the icon"
          }
        },
        "required": ["id", "icon", "label", "phaseOffset", "glowColor"]
      }
    },
    "onSelect": {
      "type": "function",
      "description": "Callback when an item is selected, receives item id"
    },
    "isWindowOpen": {
      "type": "boolean",
      "default": false,
      "description": "Whether a window/modal is currently open (triggers dismiss animation)"
    },
    "activeId": {
      "type": "string",
      "description": "Currently active item ID"
    },
    "className": {
      "type": "string",
      "default": "",
      "description": "Additional CSS classes"
    }
  },
  "slots": {},
  "examples": [
    {
      "name": "Basic orbital navigation",
      "code": "<OrbitalNav items={items} onSelect={handleSelect} isWindowOpen={false} activeId={null} />"
    },
    {
      "name": "With active item and open window",
      "code": "<OrbitalNav items={items} onSelect={handleSelect} isWindowOpen={true} activeId=\"hackathon\" />"
    }
  ]
}
