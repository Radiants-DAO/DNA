{
  "component": "NebulaBackground",
  "description": "Token bindings for NebulaBackground layered effect",
  "tokenBindings": {
    "container": {
      "position": "absolute",
      "inset": "0",
      "pointerEvents": "none",
      "overflow": "hidden"
    },
    "blurLayer": {
      "brightness": "1.47",
      "blur": "3em",
      "blendMode": "lighten"
    },
    "images": {
      "maxHeight": "69em",
      "objectFit": "contain"
    }
  },
  "assets": {
    "background": "portal_neb2.avif",
    "midground": "portal_neb1.avif",
    "foreground": "monolith_neb.avif"
  }
}
