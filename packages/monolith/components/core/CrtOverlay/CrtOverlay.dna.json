{
  "component": "CrtOverlay",
  "description": "Token bindings for CRT overlay effect",
  "tokenBindings": {
    "container": {
      "position": "fixed",
      "inset": "0",
      "zIndex": "9999",
      "pointerEvents": "none"
    },
    "scanlines": {
      "horizontalColors": ["crt-red", "crt-green", "crt-blue"],
      "verticalColors": ["crt-red", "crt-green", "crt-blue"],
      "blendMode": "overlay"
    }
  },
  "animations": {
    "scanlineShift": {
      "duration": "6s",
      "timing": "linear",
      "iteration": "infinite"
    },
    "pixelWobble": {
      "duration": "4s",
      "timing": "ease-in-out",
      "iteration": "infinite"
    },
    "bloomPulse": {
      "duration": "3s",
      "timing": "ease-in-out",
      "iteration": "infinite"
    }
  }
}
